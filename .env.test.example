# Copy to .env.test (or export) before running the E2E suite.
#
# Only DATABASE_URL is required — the app degrades gracefully when the external
# service keys below are absent, and the E2E suite is designed to pass with NONE
# of them set (free RSVP, browse, create-without-AI, onboarding, manage, etc.).

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/hykrz_e2e?schema=public"
AUTH_SECRET="e2e-test-secret-change-me"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional (leave unset for keyless E2E):
# ANTHROPIC_API_KEY=         # AI event enhance
# RAZORPAY_KEY_ID=           # paid tickets
# RAZORPAY_KEY_SECRET=
# ABLY_API_KEY=              # realtime chat / live map
# RESEND_API_KEY=            # email
# BLOB_READ_WRITE_TOKEN=     # image uploads
