# Database (Neon in production — use the DIRECT/unpooled connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/hykrz?schema=public"

# NextAuth
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Maps — free OpenStreetMap/Leaflet needs no key (Google key optional, unused for now)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Email (Resend) — verify a domain, then set EMAIL_FROM to a sender on it.
# If RESEND_API_KEY is empty, transactional emails are skipped (logged, not sent).
RESEND_API_KEY=""
EMAIL_FROM="HYKRZ <onboarding@resend.dev>"

# Durable rate limiting (Upstash Redis REST) — falls back to in-memory if unset.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Image uploads (Vercel Blob) — auto-injected on Vercel when a Blob store is
# connected. If empty, /api/upload returns 503 (uploads disabled).
BLOB_READ_WRITE_TOKEN=""

# AI (Anthropic Claude) — if empty, AI features return 503 gracefully.
ANTHROPIC_API_KEY=""

# Cron — secret for the scheduled cleanup job (Vercel sends it as a Bearer token).
CRON_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HYKRZ"
